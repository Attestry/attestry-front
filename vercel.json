{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/auth/:path*",
      "destination": "https://api.proveny.live/auth/:path*"
    },
    {
      "source": "/api/api-v1/auth/:path*",
      "destination": "https://api.proveny.live/api-v1/auth/:path*"
    },
    {
      "source": "/api/onboarding/:path*",
      "destination": "https://api.proveny.live/onboarding/:path*"
    },
    {
      "source": "/api/me/:path*",
      "destination": "https://api.proveny.live/me/:path*"
    },
    {
      "source": "/api/memberships/:path*",
      "destination": "https://api.proveny.live/memberships/:path*"
    },
    {
      "source": "/api/tenants/:path*",
      "destination": "https://api.proveny.live/tenants/:path*"
    },
    {
      "source": "/api/workflows/:path*",
      "destination": "https://api.proveny.live/workflows/:path*"
    },
    {
      "source": "/api/products/:path*",
      "destination": "https://api.proveny.live/products/:path*"
    },
    {
      "source": "/api/admin/:path*",
      "destination": "https://api.proveny.live/admin/:path*"
    },
    {
      "source": "/api/invitations/:path*",
      "destination": "https://api.proveny.live/invitations/:path*"
    },
    {
      "source": "/api/ledgers/:path*",
      "destination": "https://ledger.proveny.live/ledgers/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
